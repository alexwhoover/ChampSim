#!/bin/bash
#SBATCH --job-name=analyze_stalls
#SBATCH --output=analyze_stalls_%j.out
#SBATCH --error=analyze_stalls_%j.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --time=02:00:00
#SBATCH --mem=16G

# Wrap python_scripts/analyze_stalls.py as a batch job: it joins the two
# per-instruction stall traces, which is too heavy for the Isambard 3 head node.
#
# Usage:
#   sbatch run_shell_scripts/analyze_stalls <load_misses.txt> <load_stalls.txt> [output.txt]
# e.g.
#   sbatch run_shell_scripts/analyze_stalls \
#       results/motorBike_bertigo_load_misses.txt \
#       results/motorBike_bertigo_load_stalls.txt

set -euo pipefail

if [ "$#" -lt 2 ]; then
    echo "Usage: sbatch $0 <load_misses.txt> <load_stalls.txt> [output.txt]" >&2
    exit 1
fi

MISSES="$1"
STALLS="$2"
OUTPUT="${3:-${MISSES%load_misses.txt}stall_analysis.txt}"

CHAMPSIM_DIR=/home/b35cg/ahoover.b35cg/champ_sim
cd "$CHAMPSIM_DIR"

echo "Misses: $MISSES"
echo "Stalls: $STALLS"
echo "Start: $(date)"

python3 python_scripts/analyze_stalls.py "$MISSES" "$STALLS" > "$OUTPUT"

echo "Wrote $OUTPUT"
echo "End: $(date)"
