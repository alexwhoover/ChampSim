#!/bin/bash
#SBATCH --job-name=champsim_DTCHull_bertigo
#SBATCH --output=champsim_DTCHull_bertigo_%j.out
#SBATCH --error=champsim_DTCHull_bertigo_%j.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --time=04:00:00
#SBATCH --mem=8G

set -euo pipefail

module load gcc-native/14

CHAMPSIM_DIR=/home/b35cg/ahoover.b35cg/champ_sim
CONFIG=dpc4/1C.fullBW.bertigo.json
BINARY=bin/1C.fullBW.bertigo
TRACE=traces/DTCHull/dtchullTrace_S100B_T1B.champsimtrace.xz

cd "$CHAMPSIM_DIR"

if [ ! -f "$BINARY" ]; then
    echo "Binary not found, building..."
    ./config.sh "$CONFIG"
    make -j"$(nproc)"
fi

echo "Running ChampSim with config: $CONFIG"
echo "Trace: $TRACE"
echo "Start: $(date)"

"$BINARY" \
    --warmup-instructions 200000000 \
    --simulation-instructions 500000000 \
    "$TRACE"

echo "End: $(date)"
